<!-- ═══════════ INTERACTIVITY ═══════════ -->
<script is:inline>
  function setupTabs(tabSelector, panelSelector, dataAttr) {
    var tabs = document.querySelectorAll(tabSelector);
    var panels = document.querySelectorAll(panelSelector);

    tabs.forEach(function (tab) {
      tab.addEventListener("click", function () {
        var lang = tab.dataset[dataAttr];
        tabs.forEach(function (t) { t.classList.remove("active"); });
        tab.classList.add("active");
        panels.forEach(function (p) {
          p.classList.toggle("hidden", p.dataset[dataAttr] !== lang);
        });
      });
    });
  }

  setupTabs(".install-tab", ".install-cmd", "lang");
  setupTabs(".code-tab", ".code-panel", "code");

  document.querySelector(".install-copy").addEventListener("click", function () {
    var visible = document.querySelector(".install-cmd:not(.hidden)");
    if (visible && visible.textContent) {
      navigator.clipboard.writeText(visible.textContent);
      var btn = document.querySelector(".install-copy");
      btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
      setTimeout(function () {
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
      }, 1500);
    }
  });
</script>
