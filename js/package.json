{
  "name": "sparkid",
  "version": "2.1.0",
  "description": "Fast, time-sortable, 21-char Base58 unique ID generator",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./binary": {
      "types": "./dist/binary.d.ts",
      "import": "./dist/binary.mjs",
      "require": "./dist/binary.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "test": "tsx --test tests/test_sparkid.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "bench": "tsx bench/benchmark.ts",
    "bench:compare": "tsx bench/benchmark.ts --compare",
    "bench:binary": "tsx bench/benchmark.ts --binary"
  },
  "keywords": [
    "id",
    "uuid",
    "unique",
    "sortable",
    "base58",
    "ulid",
    "ksuid"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/youssefm/sparkid.git",
    "directory": "js"
  },
  "homepage": "https://github.com/youssefm/sparkid#javascript",
  "bugs": "https://github.com/youssefm/sparkid/issues",
  "license": "MIT",
  "engines": {
    "node": ">=19"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.2.0",
    "nanoid": "^5.1.7",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.1",
    "ulid": "^3.0.2",
    "uuid": "^13.0.0"
  }
}
